msgctxt "shortcut window"
msgid "General"
msgstr "Général"

#: data/ui/help-overlay.blp:14
msgctxt "shortcut window"
msgid "Keyboard Shortcuts"
msgstr "Raccourcis clavier"

#: data/ui/help-overlay.blp:19
msgctxt "shortcut window"
msgid "Quit"
msgstr "Quitter"

#: data/ui/help-overlay.blp:24
msgctxt "shortcut window"
msgid "Edit"
